#!/bin/bash
pushd valkey

if [ ! -f "libkallsyms.so" ]; then
    sudo cp /proc/libkallsyms.so .
fi

#check -g flag to this script
if [[ "$@" != *"-g"* ]]; then
    COMMAND="sudo LD_LIBRARY_PATH=$LD_LIBRARY_PATH:. $1"    
else
    COMMAND="sudo env -i LD_LIBRARY_PATH=$LD_LIBRARY_PATH:. gdb $2"
fi



echo $COMMAND
$COMMAND

popd


