#!/usr/bin/python3
"""
Generate a modules header file with LOAD_MODULE macros.

This script generates a header file containing:
- Extern declarations for module binary symbols
- LOAD_MODULE macro definition
- LOAD_ALL_MODULES macro that loads all specified modules
"""

import sys
import os
import argparse


def generate_modules_header(module_names, output_file):
    """
    Generate a header file with module loading macros.
    
    Args:
        module_names: List of module names (with or without .ko extension)
        output_file: Path to the output header file
    """
    # Strip .ko extension if present
    module_names = [name.removesuffix('.ko') for name in module_names]
    
    include_guard = os.path.basename(output_file).replace('.', '_').upper() + "_"
    
    header_content = [
        f"#ifndef {include_guard}",
        f"#define {include_guard}",
        "",
        "// Auto-generated module loading header",
        "",
    ]
    
    # Generate extern declarations for each module
    if module_names:
        header_content.append("// Module binary symbols")
        for modname in module_names:
            header_content.extend([
                f"extern const char _binary_{modname}_ko_start[];",
                f"extern const char _binary_{modname}_ko_end[];",
                f"extern const char _binary_{modname}_ko_size;",
            ])
        header_content.append("")
    
    # Generate LOAD_MODULE macro
    header_content.extend([
        "// Macro to load a single module, init_module handles the case where it's already loaded and will print a message instead of erroring out",
        "#define LOAD_MODULE(modname) do {\\",
        "    size_t size = (size_t)&_binary_##modname##_ko_size;\\",
        "    ret = init_module((void*)_binary_##modname##_ko_start, size, \"\"); \\",
        "  } while(0)",
        "",
    ])
    
    # Generate LOAD_ALL_MODULES macro
    header_content.append("// Macro to load all modules")
    separator = "\\" 
    if module_names:
        header_content.append("#define LOAD_ALL_MODULES() do {\\")
        for i, modname in enumerate(module_names):
            header_content.append(f"    LOAD_MODULE({modname});{separator}")
        header_content.append("  } while(0)")
    else:
        # Empty macro if no modules
        header_content.append("#define LOAD_ALL_MODULES() do { } while(0)")
    
    header_content.extend([
        "",
        f"#endif // {include_guard}",
    ])
    
    # Write to file
    with open(output_file, 'w') as f:
        f.write('\n'.join(header_content))
        f.write('\n')
    
    print(f"Generated {output_file} with {len(module_names)} module(s)")


def main():
    parser = argparse.ArgumentParser(
        description='Generate a header file for loading kernel modules',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Example usage:
  %(prog)s -o modules.h ext ipc_interposer
  %(prog)s -o modules.h ext.ko ipc_interposer.ko
  %(prog)s -o modules.h ext
  %(prog)s modules.h ext.ko ipc_interposer net_filter.ko

This will generate a header file with LOAD_MODULE macros for the specified modules.
Module names can be provided with or without the .ko extension.
        """
    )
    
    parser.add_argument(
        '-o', '--output',
        required=True,
        help='Output header file path'
    )
    
    parser.add_argument(
        'modules',
        nargs='*',
        help='Module names (with or without .ko extension)'
    )
    
    args = parser.parse_args()
    
    if not args.modules:
        print("Warning: No modules specified. Generating empty header.", file=sys.stderr)
    
    generate_modules_header(args.modules, args.output)


if __name__ == "__main__":
    main()
