import clang.cindex
import sys
import os

# --- (Optional) Manual configuration if libclang is not found automatically ---
# clang.cindex.Config.set_library_file('/usr/lib/llvm-14/lib/libclang.so') 

def get_function_prototype_ifunc(cursor):
    """Extracts the full function prototype string for a declaration."""
    return_type = cursor.result_type.spelling
    func_name = cursor.spelling
    params = []
    for child in cursor.get_children():
        if child.kind == clang.cindex.CursorKind.PARM_DECL:
            param_type = child.type.spelling
            param_name = child.spelling
            params.append(f"{param_type} {param_name}")
    
    params_str = ', '.join(params) if params else 'void'
    return func_name, f"extern {return_type} {func_name}({params_str});", f"DECLARE_IFUNC({func_name}, {return_type}, ({params_str}))", f"    void* {func_name};", f"DEFINE_GOT_FUNC({func_name}, {return_type}, ({params_str}))"

def get_global_variable_declaration(cursor):
    """Extracts the declaration string for a global variable."""
    var_name = cursor.spelling
    var_type = cursor.type.spelling
    return f"extern {var_type} {var_name};"

def process_app_files(app_header_filename):
    """
    Processes multiple C files and aggregates function prototypes and GOT declarations.
    """
    index = clang.cindex.Index.create()
    all_function_prototypes = set() # Use a set to avoid duplicate declarations
    got_declarations = set()
    function_definitions = set()
    got_derefs = set()
    func_names = set()

    print(f"Parsing {app_header_filename}...")
    tu = index.parse(app_header_filename, args=['-std=c99'])
    
    if not tu:
        print(f"Error: Unable to parse translation unit for {app_header_filename}. Skipping.")
        return

    for cursor in tu.cursor.get_children():
        # Only consider declarations belonging to the current source file being parsed
        if cursor.location.file and os.path.abspath(cursor.location.file.name) != os.path.abspath(app_header_filename):
            continue

        #dont include static ones
        if cursor.linkage == clang.cindex.LinkageKind.INTERNAL:
            continue


        if cursor.kind == clang.cindex.CursorKind.FUNCTION_DECL:
            func_name, prototype, _, got_declaration, function_definition = get_function_prototype_ifunc(cursor)
            if func_name == "main":
                continue  # Skip main function
            func_names.add(func_name)


            if prototype:
                all_function_prototypes.add(prototype)
            if got_declaration:
                got_declarations.add(got_declaration)
            if function_definition:
                function_definitions.add(function_definition)
                
        elif cursor.kind == clang.cindex.CursorKind.VAR_DECL:
            continue # We can not link to global variables from the application because of the kernels memory model (32 bit relative addressing)


    return sorted(list(all_function_prototypes)), sorted(list(got_declarations)), sorted(list(function_definitions)), sorted(list(func_names))




def write_app_files(user_header_filename, kernel_header_filename, func_protos, got_declarations, function_definitions, func_names):
    """Writes the app file with function prototypes and GOT declarations."""
    include_guard = os.path.basename(kernel_header_filename).replace('.', '_').upper() + "_" + "EXT_"
    kernel_header_content = [
        f"#ifndef {include_guard}",
        f"#define {include_guard}",
        # "",
        # "#include \"app_orig.h\"",
        "",
        "#ifdef __cplusplus",
        "extern \"C\" {",
        "#endif",
        ""]
    if not got_declarations:
        got_declarations.append("void* dummy; // No GOT entries found, dummy entry to avoid empty struct")
        kernel_header_content.append("#define NO_APP_GOT_ENTRIES")


    if got_declarations:
        kernel_header_content.append("typedef struct {")
        kernel_header_content.append("// GOT Declarations")
        kernel_header_content.extend(got_declarations)
        kernel_header_content.append("} app_got_t;")
        kernel_header_content.append("")
    
    kernel_header_content.extend([
        "extern app_got_t* app_got; // this is defined in init.c generated by kcc",
        "",
        "#define DEFINE_GOT_FUNC(func_name, rettype, args) \\",
        "static inline rettype func_name args { \\",
        "asm volatile ( \\",
        "   \"jmp *%0\" \\",
        "   : \\",
        "   : \"r\"(app_got->func_name) \\",
        "   ); \\",
        "   unreachable(); \\",
        "}",
        "",
    ])

    if function_definitions:
        kernel_header_content.append("")
        kernel_header_content.append("// Function Definitions")
        kernel_header_content.extend(function_definitions)
    

    kernel_header_content.extend([
        "#ifdef __cplusplus",
        "}",
        "#endif",
        "",
        f"#endif // {include_guard}"
    ])


    
    include_guard = os.path.basename(user_header_filename).replace('.', '_').upper() + "_" + "EXT_"
    user_header_content = [
        f"#ifndef {include_guard}",
        f"#define {include_guard}",
        "",
        "#include \"app_orig.h\"",
        "",
        "#ifdef __cplusplus",
        "extern \"C\" {",
        "#endif",
        "",
        "#define SET_APP_GOT_FUNC(func_name) \\",
        "    app_got->func_name = (void *)&func_name;",
        ""
    ]


    if got_declarations:
        user_header_content.append("typedef struct {")
        user_header_content.append("// GOT Declarations")
        user_header_content.extend(got_declarations)
        user_header_content.append("} app_got_t;")
        user_header_content.append("")

        

    if func_protos:
        user_header_content.append("")
        # user_header_content.append("#ifdef DECLARE_ALL_FUNCS")
        user_header_content.append("// Function Prototypes")
        user_header_content.extend(func_protos)

        user_header_content.append("")
        user_header_content.append("//Set GOT logic")
        user_header_content.append("#define SET_ALL_GOT_ENTRIES() \\")

        for func_name in func_names:
            user_header_content.append(f"SET_APP_GOT_FUNC({func_name}); \\")
        
        user_header_content.append("")
        # user_header_content.append("#endif")
        user_header_content.append("")
    
    else:
        # noop macro
        user_header_content.append("#define SET_ALL_GOT_ENTRIES() // No functions found, no GOT entries to set")

    user_header_content.extend([
        "#ifdef __cplusplus",
        "}",
        "#endif",
        "",
        f"#endif // {include_guard}"
    ])

    with open(user_header_filename, 'w+') as f:
        f.write('\n'.join(user_header_content))

    with open(kernel_header_filename, 'w+') as f:
        f.write('\n'.join(kernel_header_content))

        
    print(f"\nSuccessfully generated: {user_header_filename}")



if __name__ == "__main__":
    # sys.argv[0] is the script name, sys.argv[1:] is the list of source files

    if len(sys.argv) < 4:
        print(f"Usage: {sys.argv[0]} <kernel_output.h> <user_output.h> <input.kh>")
        sys.exit(1)
    
    kernel_output_header_name = sys.argv[1]
    user_output_header_name = sys.argv[2]
    input_header_name = sys.argv[3]
    
    
    app_functions_list, got_declarations, function_definitions, func_names = process_app_files(input_header_name)
    write_app_files(user_output_header_name,kernel_output_header_name, app_functions_list, got_declarations, function_definitions, func_names)

