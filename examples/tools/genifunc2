def get_function_prototype_ifunc(cursor):
    """Extracts the full function prototype string for a declaration."""
    return_type = cursor.result_type.spelling
    func_name = cursor.spelling
    params = []
    for child in cursor.get_children():
        if child.kind == clang.cindex.CursorKind.PARM_DECL:
            param_type = child.type.spelling
            param_name = child.spelling
            params.append(f"{param_type} {param_name}")
    
    params_str = ', '.join(params) if params else 'void'
    return func_name, f"extern {return_type} {func_name}({params_str});", f"DECLARE_IFUNC({func_name}, {return_type}, ({params_str}))", f"    void* {func_name};", f"DEFINE_GOT_FUNC({func_name}, {return_type}, ({params_str}))"

def get_global_variable_declaration(cursor):
    """Extracts the declaration string for a global variable."""
    var_name = cursor.spelling
    var_type = cursor.type.spelling
    return f"extern {var_type} {var_name};"

def process_input_headers(source_filenames):
    """
    Processes extension header file and aggregates declarations.
    """
    index = clang.cindex.Index.create()
    all_function_prototypes = set() # Use a set to avoid duplicate declarations
    all_ifuncs = set()
    all_global_variables = set()

    all_function_prototypes.add("extern void set_app_got(app_got_t* got);")  # Manually add set_app_got declaration

    for source_filename in source_filenames:
        print(f"Parsing {source_filename}...")
        tu = index.parse(source_filename, args=['-std=c99'])
        
        if not tu:
            print(f"Error: Unable to parse translation unit for {source_filename}. Skipping.")
            continue

        for cursor in tu.cursor.get_children():
            # Only consider declarations belonging to the current source file being parsed
            if cursor.location.file and os.path.abspath(cursor.location.file.name) != os.path.abspath(source_filename):
                continue

            #dont include static ones
            if cursor.linkage == clang.cindex.LinkageKind.INTERNAL:
                continue

            if cursor.kind == clang.cindex.CursorKind.FUNCTION_DECL:
                _, prototype,ifunc,_,_ = get_function_prototype_ifunc(cursor)
                if prototype:
                    all_function_prototypes.add(prototype)
                if ifunc:
                    all_ifuncs.add(ifunc)
                    
            elif cursor.kind == clang.cindex.CursorKind.VAR_DECL:
                # Filter out static variables and local variables
                #if cursor.linkage == clang.cindex.Linkage.EXTERNAL and cursor.is_definition():
                declaration = get_global_variable_declaration(cursor)
                if declaration:
                    all_global_variables.add(declaration)
                        
    return sorted(list(all_global_variables)), sorted(list(all_function_prototypes)), sorted(list(all_ifuncs))

def process_app_files(source_filenames):
    """
    Processes multiple C files and aggregates function prototypes and GOT declarations.
    """
    index = clang.cindex.Index.create()
    all_function_prototypes = set() # Use a set to avoid duplicate declarations
    got_declarations = set()
    function_definitions = set()
    got_derefs = set()
    func_names = set()

    for source_filename in source_filenames:
        print(f"Parsing {source_filename}...")
        tu = index.parse(source_filename, args=['-std=c99'])
        
        if not tu:
            print(f"Error: Unable to parse translation unit for {source_filename}. Skipping.")
            continue

        for cursor in tu.cursor.get_children():
            # Only consider declarations belonging to the current source file being parsed
            if cursor.location.file and os.path.abspath(cursor.location.file.name) != os.path.abspath(source_filename):
                continue

            #dont include static ones
            if cursor.linkage == clang.cindex.LinkageKind.INTERNAL:
                continue


            if cursor.kind == clang.cindex.CursorKind.FUNCTION_DECL and cursor.is_definition():
                func_name, prototype, _, got_declaration, function_definition = get_function_prototype_ifunc(cursor)
                if func_name == "main":
                    continue  # Skip main function
                func_names.add(func_name)


                if prototype:
                    all_function_prototypes.add(prototype)
                if got_declaration:
                    got_declarations.add(got_declaration)
                if function_definition:
                    function_definitions.add(function_definition)
                    
            elif cursor.kind == clang.cindex.CursorKind.VAR_DECL:
                continue # We can not link to global variables from the application because of the kernels memory model (32 bit relative addressing)


    return sorted(list(all_function_prototypes)), sorted(list(got_declarations)), sorted(list(function_definitions)), sorted(list(func_names))



def write_ext_files( c_filename, ifuncs):
    """Writes the aggregated declarations to a single header file."""
    c_content = [
        "extern void *dpld_resolver(char * symbol_name);",
        "",
        "// macro to define a function as an ifunc and to define a simple",
        "// resolver that calls the base_resolver",
        "#define DECLARE_IFUNC(name, rettype, args) \\",
        "   rettype name args __attribute__((ifunc(#name \"_resolver\"))); \\",
        "   static rettype (*name##_resolver(void)) args { \\",
        "      return (rettype (*) args) dpld_resolver(#name); \\",
        "   } ",
        ""
    ]
    if ifuncs:
        c_content.append("// generate ifunc for ext function found")
        c_content.extend(ifuncs)
        c_content.append("")

    # with open(header_filename, 'w+') as f:
    #     f.write('\n'.join(header_content))

    with open(c_filename, 'w+') as f:
        f.write('\n'.join(c_content))
        
    print(f"\nSuccessfully generated: {c_filename}")

def write_app_files(header_filename, func_protos, got_declarations, function_definitions, func_names):
    """Writes the app file with function prototypes and GOT declarations."""
    include_guard = os.path.basename(header_filename).replace('.', '_').upper() + "_"
    header_content = [
        f"#ifndef {include_guard}",
        f"#define {include_guard}",
        "",
        "#ifdef __cplusplus",
        "extern \"C\" {",
        "#endif",
        "",
        "#define SET_APP_GOT_FUNC(func_name) \\",
        "    app_got->func_name = (void *)&func_name;",
        "",
        "#ifdef __KERNEL__",
        "#define DEFINE_GOT_FUNC(func_name, rettype, args) \\",
        "static inline rettype func_name args { \\",
        "asm volatile ( \\",
        "   \"jmp *%0\" \\",
        "   : \\",
        "   : \"r\"(app_got->func_name) \\",
        "   ); \\",
        "   unreachable(); \\",
        "}",
        "",
        "#endif"
    ]

    if not got_declarations:
        got_declarations.append("void* dummy; // No GOT entries found, dummy entry to avoid empty struct")
        header_content.append("#define NO_APP_GOT_ENTRIES")

    if got_declarations:
        header_content.append("typedef struct {")
        header_content.append("// GOT Declarations")
        header_content.extend(got_declarations)
        header_content.append("} app_got_t;")
        header_content.append("")

        
    header_content.append("#ifdef __KERNEL__")
    header_content.append("extern app_got_t* app_got;")
    header_content.append("#endif")

    if function_definitions:
        header_content.append("")
        header_content.append("#ifdef __KERNEL__")
        header_content.append("// Function Definitions")
        header_content.extend(function_definitions)
        header_content.append("#endif")

    if func_protos:
        header_content.append("")
        header_content.append("#ifdef DECLARE_ALL_FUNCS")
        header_content.append("// Function Prototypes")
        header_content.extend(func_protos)

        header_content.append("")
        header_content.append("//Set GOT logic")
        header_content.append("#define SET_ALL_GOT_ENTRIES() \\")

        for func_name in func_names:
            header_content.append(f"SET_APP_GOT_FUNC({func_name}); \\")
        
        header_content.append("")
        header_content.append("#endif")
        header_content.append("")
    
    else:
        # noop macro
        header_content.append("#define SET_ALL_GOT_ENTRIES() // No functions found, no GOT entries to set")

    header_content.extend([
        "#ifdef __cplusplus",
        "}",
        "#endif",
        "",
        f"#endif // {include_guard}"
    ])

    with open(header_filename, 'w+') as f:
        f.write('\n'.join(header_content))

        
    print(f"\nSuccessfully generated: {header_filename}")



if __name__ == "__main__":
    # sys.argv[0] is the script name, sys.argv[1:] is the list of source files

    if len(sys.argv) < 5:
        print(f"Usage: {sys.argv[0]} <outputA.h> <outputA.c> <outputB.h> <app_directory>")
        sys.exit(1)
    
    input_header_name = sys.argv[1]
    output_c_name = sys.argv[2]
    output_header_name_b = sys.argv[3]
    app_directory = sys.argv[4]



    globals_list, functions_list, ifunc_list = process_input_headers([input_header_name])
    write_ext_files(output_c_name, ifunc_list)
    
    
    app_cfiles = [os.path.join(app_directory, f) for f in os.listdir(app_directory) if f.endswith('.c')]
    app_functions_list, got_declarations, function_definitions, func_names = process_app_files(app_cfiles)
    write_app_files(output_header_name_b, app_functions_list, got_declarations, function_definitions, func_names)


